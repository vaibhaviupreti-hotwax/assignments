				{
					"name": "pack",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// 1. Check pack was successful",
									"pm.test(\"Pack successful - status 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Pack response has shipmentId\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property(\"shipmentId\");",
									"});",
									"",
									"// 2. Auto-call ship API after pack",
									"const shipmentId = \"M100363\"; // or read dynamically if response returns it",
									"",
									"const shipRequest = {",
									"    url: `https://nextgen-maarg.hotwax.io/rest/s1/poorti/shipments/${shipmentId}/ship`,",
									"    method: \"POST\",",
									"    header: {",
									"        \"Content-Type\": \"application/json\",",
									"        \"Authorization\": `Bearer ${pm.collectionVariables.get(\"shipment-token\")}`",
									"    },",
									"    body: {",
									"        mode: \"raw\",",
									"        raw: JSON.stringify({ shipmentId: shipmentId })",
									"    }",
									"};",
									"",
									"pm.sendRequest(shipRequest, function (err, res) {",
									"    pm.test(\"Ship successful - status 200\", function () {",
									"        pm.expect(res).to.have.status(200);",
									"    });",
									"",
									"    pm.test(\"Ship response is valid\", function () {",
									"        const json = res.json();",
									"        console.log(\"Ship response:\", JSON.stringify(json));",
									"    });",
									"});"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
