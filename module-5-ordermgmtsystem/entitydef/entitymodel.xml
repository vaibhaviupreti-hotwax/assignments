<entitymodel xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://ofbiz.apache.org/dtds/entitymodel.xsd">
    <!-- ========================================================= -->
    <!-- ======================== Defaults ======================= -->
    <!-- ========================================================= -->
    <title>Entity of Ordermgmtsystem Component</title>
    <description>None</description>
    <copyright></copyright>
    <version></version>

    <!-- Order Header Entity -->
    <entity entity-name="OmsOrderHeader" package-name="org.apache.ofbiz.ordermgmtsystem">
        <field name="orderId" type="id"/>
        <field name="orderTypeId" type="id"/>
        <field name="statusId" type="id"/>
        <field name="orderDate" type="date-time"/>
        <prim-key field="orderId"/>
    </entity>

    <!-- Order Part Entity -->
    <entity entity-name="OmsOrderPart" package-name="org.apache.ofbiz.ordermgmtsystem">
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="customerPartyId" type="id"/>
        <field name="vendorPartyId" type="id"/>
        <field name="postalContactMechId" type="id"/>
        <field name="telecomContactMechId" type="id"/>
        <field name="statusId" type="id"/>
        <field name="partTotal" type="currency-amount"/>
        <prim-key field="orderId"/>
        <prim-key field="orderPartSeqId"/>
        <relation type="one" fk-name="OMS_OP_OH" rel-entity-name="OmsOrderHeader">
            <key-map field-name="orderId"/>
        </relation>
    </entity>

    <!-- Order Item Entity -->
    <entity entity-name="OmsOrderItem" package-name="org.apache.ofbiz.ordermgmtsystem">
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="orderItemSeqId" type="id"/>
        <field name="parentItemSeqId" type="id"/>
        <field name="productId" type="id"/>
        <field name="quantity" type="fixed-point"/>
        <field name="unitPrice" type="currency-amount"/>
        <prim-key field="orderId"/>
        <prim-key field="orderPartSeqId"/>
        <prim-key field="orderItemSeqId"/>
        <relation type="one" fk-name="OMS_OI_OP" rel-entity-name="OmsOrderPart">
            <key-map field-name="orderId"/>
            <key-map field-name="orderPartSeqId"/>
        </relation>
    </entity>
    
    <!-- Order Item Association -->
    <entity entity-name="OmsOrderItemAssoc" package-name="org.apache.ofbiz.ordermgmtsystem">
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="orderItemSeqId" type="id"/>
        <field name="toOrderId" type="id"/>
        <field name="toOrderPartSeqId" type="id"/>
        <field name="toOrderItemSeqId" type="id"/>
        <field name="orderItemAssocTypeId" type="id"/>
        <prim-key field="orderId"/>
        <prim-key field="orderPartSeqId"/>
        <prim-key field="orderItemSeqId"/>
        <prim-key field="toOrderId"/>
        <prim-key field="toOrderPartSeqId"/>
        <prim-key field="toOrderItemSeqId"/>
        <prim-key field="orderItemAssocTypeId"/>
        <relation type="one" fk-name="OMS_OIA_FROM" rel-entity-name="OmsOrderItem">
            <key-map field-name="orderId"/>
            <key-map field-name="orderPartSeqId"/>
            <key-map field-name="orderItemSeqId"/>
        </relation>
        <relation type="one" fk-name="OMS_OIA_TO" rel-entity-name="OmsOrderItem">
            <key-map field-name="toOrderId" rel-field-name="orderId"/>
            <key-map field-name="toOrderPartSeqId" rel-field-name="orderPartSeqId"/>
            <key-map field-name="toOrderItemSeqId" rel-field-name="orderItemSeqId"/>
        </relation>
    </entity>

    <!-- Order Contact Mech Entity -->
    <entity entity-name="OmsOrderContactMech" package-name="org.apache.ofbiz.ordermgmtsystem">
        <field name="orderId" type="id"/>
        <field name="contactMechPurposeTypeId" type="id"/>
        <field name="contactMechId" type="id"/>
        <prim-key field="orderId"/>
        <prim-key field="contactMechPurposeTypeId"/>
        <prim-key field="contactMechId"/>
        <relation type="one" fk-name="OMS_OCM_OH" rel-entity-name="OmsOrderHeader">
            <key-map field-name="orderId"/>
        </relation>
    </entity>

    <!-- Order Status Entity -->
    <entity entity-name="OmsOrderStatus" package-name="org.apache.ofbiz.ordermgmtsystem">
        <field name="orderStatusId" type="id"/>
        <field name="statusId" type="id"/>
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="orderItemSeqId" type="id"/>
        <field name="statusDatetime" type="date-time"/>
        <prim-key field="orderStatusId"/>
        <relation type="one" fk-name="OMS_OS_OH" rel-entity-name="OmsOrderHeader">
            <key-map field-name="orderId"/>
        </relation>
    </entity>

    <!-- Order Adjustment Entity -->
    <entity entity-name="OmsOrderAdjustment" package-name="org.apache.ofbiz.ordermgmtsystem">
        <field name="orderAdjustmentId" type="id"/>
        <field name="orderAdjustmentTypeId" type="id"/>
        <field name="orderId" type="id"/>
        <field name="orderPartSeqId" type="id"/>
        <field name="orderItemSeqId" type="id"/>
        <field name="amount" type="currency-amount"/>
        <prim-key field="orderAdjustmentId"/>
        <relation type="one" fk-name="OMS_OA_OH" rel-entity-name="OmsOrderHeader">
            <key-map field-name="orderId"/>
        </relation>
    </entity>

    <!-- Order Payment Preference Entity -->
    <entity entity-name="OmsOrderPaymentPreference" package-name="org.apache.ofbiz.ordermgmtsystem">
        <field name="orderPaymentPreferenceId" type="id"/>
        <field name="orderId" type="id"/>
        <field name="paymentMethodTypeId" type="id"/>
        <field name="paymentMethodId" type="id"/>
        <field name="maxAmount" type="currency-amount"/>
        <field name="statusId" type="id"/>
        <prim-key field="orderPaymentPreferenceId"/>
        <relation type="one" fk-name="OMS_OPP_OH" rel-entity-name="OmsOrderHeader">
            <key-map field-name="orderId"/>
        </relation>
    </entity>

</entitymodel>
