<site-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Site-Conf" xsi:schemaLocation="http://ofbiz.apache.org/Site-Conf http://ofbiz.apache.org/dtds/site-conf.xsd">
    <include location="component://common/webcommon/WEB-INF/common-controller.xml"/>
    <description>Ordermgmtsystem Component Site Configuration File</description>

    <!-- Request Mappings -->
    <request-map uri="main"><security https="true" auth="true"/><response name="success" type="view" value="main"/></request-map>
    
    <!-- OmsOrderHeader Requests -->
    <request-map uri="FindOmsOrderHeader"><security https="true" auth="true"/><response name="success" type="view" value="FindOmsOrderHeader"/></request-map>
    <request-map uri="EditOmsOrderHeader"><security https="true" auth="true"/><response name="success" type="view" value="EditOmsOrderHeader"/></request-map>
    <request-map uri="createOmsOrderHeader">
        <security https="true" auth="true"/>
        <event type="service" invoke="createOmsOrderHeader"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>
    <request-map uri="updateOmsOrderHeader">
        <security https="true" auth="true"/>
        <event type="service" invoke="updateOmsOrderHeader"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>
    <request-map uri="deleteOmsOrderHeader">
        <security https="true" auth="true"/>
        <event type="service" invoke="deleteOmsOrderHeader"/>
        <response name="success" type="request-redirect" value="FindOmsOrderHeader"/>
    </request-map>

    <!-- OmsOrderPart Requests -->
    <request-map uri="createOmsOrderPart">
        <security https="true" auth="true"/>
        <event type="service" invoke="createOmsOrderPart"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>
    <request-map uri="updateOmsOrderPart">
        <security https="true" auth="true"/>
        <event type="service" invoke="updateOmsOrderPart"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>
    <request-map uri="deleteOmsOrderPart">
        <security https="true" auth="true"/>
        <event type="service" invoke="deleteOmsOrderPart"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>

    <!-- OmsOrderItem Requests -->
    <request-map uri="createOmsOrderItem">
        <security https="true" auth="true"/>
        <event type="service" invoke="createOmsOrderItem"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>
    <request-map uri="updateOmsOrderItem">
        <security https="true" auth="true"/>
        <event type="service" invoke="updateOmsOrderItem"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>
    <request-map uri="deleteOmsOrderItem">
        <security https="true" auth="true"/>
        <event type="service" invoke="deleteOmsOrderItem"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>

    <!-- OmsOrderContactMech Requests -->
    <request-map uri="createOmsOrderContactMech">
        <security https="true" auth="true"/>
        <event type="service" invoke="createOmsOrderContactMech"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>
    <request-map uri="deleteOmsOrderContactMech">
        <security https="true" auth="true"/>
        <event type="service" invoke="deleteOmsOrderContactMech"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>

    <!-- OmsOrderStatus Requests -->
    <request-map uri="createOmsOrderStatus">
        <security https="true" auth="true"/>
        <event type="service" invoke="createOmsOrderStatus"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>
    <request-map uri="deleteOmsOrderStatus">
        <security https="true" auth="true"/>
        <event type="service" invoke="deleteOmsOrderStatus"/>
        <response name="success" type="view" value="EditOmsOrderHeader"/>
    </request-map>

    <!-- View Mappings -->
    <view-map name="main" type="screen" page="component://ordermgmtsystem/widget/OrdermgmtsystemScreens.xml#main"/>
    <view-map name="FindOmsOrderHeader" type="screen" page="component://ordermgmtsystem/widget/OrdermgmtsystemScreens.xml#FindOmsOrderHeader"/>
    <view-map name="EditOmsOrderHeader" type="screen" page="component://ordermgmtsystem/widget/OrdermgmtsystemScreens.xml#EditOmsOrderHeader"/>
</site-conf>
