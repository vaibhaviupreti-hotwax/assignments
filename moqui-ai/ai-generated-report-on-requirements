## 7. Corrected Entity Definition (Recommended)

```xml
<!-- Generic config change staging entity -->
<entity entity-name="ConfigChangeRequest" package="co.hotwax.oms">
    <description>Staging entity for configuration changes requiring human approval.
    Modeled after AiToolCallRequest. A record is created instead of applying
    the change directly; it transitions PENDING → APPROVED/REJECTED.</description>

    <!-- Identity -->
    <field name="changeRequestId"   type="id"          is-pk="true"/>

    <!-- What is being changed -->
    <field name="targetEntityName"  type="text-medium"/>
    <!-- e.g. "moqui.service.job.ServiceJob" -->
    <field name="targetPrimaryKey"  type="text-medium"/>
    <!-- e.g. "approve_rejectedItemsCycleCount_STORE" (JSON for compound PKs) -->
    <field name="operationType"     type="text-medium"/>
    <!-- e.g. "UPDATE_SERVICE_JOB", "PAUSE_SERVICE_JOB", "UPDATE_PARAMETERS" -->

    <!-- The payload — both states captured at request time -->
    <field name="applicationData"   type="text-very-long"/>
    <!-- JSON: { "currentState": {...}, "proposedState": {...} } -->

    <!-- Timestamps -->
    <field name="requestedDateTime" type="date-time"/>
    <field name="decisionDateTime"  type="date-time"/>

    <!-- Participants -->
    <field name="requestedByUserId" type="id-long"/>
    <field name="approvedByUserId"  type="id-long"/>   <!-- null until decision -->

    <!-- State machine -->
    <field name="statusId"          type="id"/>
    <!-- PENDING, APPROVED, REJECTED -->

    <!-- Decision context -->
    <field name="decisionNote"      type="text-long"/>

    <!-- UI routing (optional — can be derived from targetEntityName + operationType) -->
    <field name="reviewScreenPath"  type="text-medium"/>

    <!-- Relationships -->
    <relationship type="one" related="moqui.security.UserAccount"
                  fk-name="CCR_REQ_USER"  field-map="requestedByUserId:userId"/>
    <relationship type="one" related="moqui.security.UserAccount"
                  fk-name="CCR_APR_USER"  field-map="approvedByUserId:userId"/>
    <relationship type="one" related="moqui.basic.StatusItem" fk-name="CCR_STATUS"/>
</entity>
```

